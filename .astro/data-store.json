[["Map",1,2,9,10],"meta::meta",["Map",3,4,5,6,7,8],"astro-version","5.18.1","content-config-digest","3da08a7be4dfe853","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://your-blog.pages.dev\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":true,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":true,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","posts",["Map",11,12],"accept-imperfection",{"id":11,"data":13,"body":20,"filePath":21,"digest":22,"rendered":23,"legacyId":40},{"title":14,"date":15,"tags":16,"draft":19},"学会接受不完美",["Date","2026-05-10T00:00:00.000Z"],[17,18],"心态","成长",false,"最近一直在想一个问题：为什么我们总是追求完美，却很少学会接受不完美？\n\n## 完美主义的陷阱\n\n我发现自己经常陷入这样的循环：\n\n1. 想做一件事\n2. 觉得自己还没准备好\n3. 一直等待\"完美时机\"\n4. 最终什么都没做\n\n这就是完美主义最大的陷阱——**它让你什么都不做**。\n\n## 不完美才是常态\n\n> 完成比完美更重要。\n\n这句话我听过很多次，但直到最近才真正理解。一个完成的不完美作品，永远比一个完美的空想更有价值。\n\n## 我的改变\n\n从今天起，我决定：\n\n- 允许自己写出\"不够好\"的文章\n- 允许自己犯错，然后从错误中学习\n- 把\"先完成，再完善\"作为行动准则\n\n不完美，也是一种美。","src/content/posts/accept-imperfection.md","d3057860b58cb435",{"html":24,"metadata":25},"\u003Cp>最近一直在想一个问题：为什么我们总是追求完美，却很少学会接受不完美？\u003C/p>\n\u003Ch2 id=\"完美主义的陷阱\">完美主义的陷阱\u003C/h2>\n\u003Cp>我发现自己经常陷入这样的循环：\u003C/p>\n\u003Col>\n\u003Cli>想做一件事\u003C/li>\n\u003Cli>觉得自己还没准备好\u003C/li>\n\u003Cli>一直等待”完美时机”\u003C/li>\n\u003Cli>最终什么都没做\u003C/li>\n\u003C/ol>\n\u003Cp>这就是完美主义最大的陷阱——\u003Cstrong>它让你什么都不做\u003C/strong>。\u003C/p>\n\u003Ch2 id=\"不完美才是常态\">不完美才是常态\u003C/h2>\n\u003Cblockquote>\n\u003Cp>完成比完美更重要。\u003C/p>\n\u003C/blockquote>\n\u003Cp>这句话我听过很多次，但直到最近才真正理解。一个完成的不完美作品，永远比一个完美的空想更有价值。\u003C/p>\n\u003Ch2 id=\"我的改变\">我的改变\u003C/h2>\n\u003Cp>从今天起，我决定：\u003C/p>\n\u003Cul>\n\u003Cli>允许自己写出”不够好”的文章\u003C/li>\n\u003Cli>允许自己犯错，然后从错误中学习\u003C/li>\n\u003Cli>把”先完成，再完善”作为行动准则\u003C/li>\n\u003C/ul>\n\u003Cp>不完美，也是一种美。\u003C/p>",{"headings":26,"localImagePaths":34,"remoteImagePaths":35,"frontmatter":36,"imagePaths":39},[27,30,32],{"depth":28,"slug":29,"text":29},2,"完美主义的陷阱",{"depth":28,"slug":31,"text":31},"不完美才是常态",{"depth":28,"slug":33,"text":33},"我的改变",[],[],{"title":14,"date":37,"tags":38},["Date","2026-05-10T00:00:00.000Z"],[17,18],[],"accept-imperfection.md"]